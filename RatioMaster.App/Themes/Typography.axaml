<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

  <!-- Segoe UI on Windows, Inter (bundled) as fallback, then sans-serif.
       Consolas / Cascadia for the monospace log. -->
  <FontFamily x:Key="UiFontFamily">Segoe UI, Inter, sans-serif</FontFamily>
  <FontFamily x:Key="MonoFontFamily">Consolas, Cascadia Code, Cascadia Mono, monospace</FontFamily>

  <sys:Double x:Key="FontSizeXs">10.5</sys:Double>
  <sys:Double x:Key="FontSizeSm">11.5</sys:Double>
  <sys:Double x:Key="FontSizeBody">12.5</sys:Double>
  <sys:Double x:Key="FontSizeUi">13</sys:Double>
  <sys:Double x:Key="FontSizeMd">14</sys:Double>
  <sys:Double x:Key="FontSizeLg">16</sys:Double>
  <sys:Double x:Key="FontSizeXl">19</sys:Double>

</ResourceDictionary>
